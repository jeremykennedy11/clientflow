JWT_SECRET=change-me
APP_URL=http://localhost:3000

# Required only on Vercel — auth for the /api/reminders/run and /api/recurring/run cron
# endpoints (see vercel.json "crons"). Vercel calls them with "Authorization: Bearer <this>".
# Set the same value in the Vercel project's environment variables.
CRON_SECRET=

# Frontend (Vite) — where the browser reaches the API. Leave unset in production: the app
# defaults to same-origin "/api/..." once deployed, since frontend + API share one Vercel project.
VITE_API_BASE_URL=http://localhost:3001

# Supabase — use a secret key (sb_secret_...), keep the bucket private
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend) — sending domain verified: useclientflowapp.com
RESEND_API_KEY=
RESEND_FROM=noreply@useclientflowapp.com

# AI (Clara) — Anthropic preferred, OpenAI fallback
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Stripe — all four required for real billing; leave empty for demo mode
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_FIRM=
