{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/reminders/run", "schedule": "0 13 * * *" },
    { "path": "/api/recurring/run", "schedule": "5 13 * * *" }
  ]
}
